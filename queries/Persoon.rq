# Persoon 
SELECT DISTINCT ?Persoon_url ?heeftStandplaats_url ?achternaam ?voornaam ?volledigeNaam ?geslacht_url WHERE {
  ?Persoon_url a <http://www.w3.org/ns/person#Person> .
  OPTIONAL { ?Persoon_url <http://www.w3.org/ns/org#basedAt> ?heeftStandplaats_url . }
  OPTIONAL { ?Persoon_url <http://xmlns.com/foaf/0.1/familyName> ?achternaam . }
  OPTIONAL { ?Persoon_url <http://xmlns.com/foaf/0.1/givenName> ?voornaam . }
  OPTIONAL { ?Persoon_url <https://data.vlaanderen.be/ns/persoon#volledigeNaam> ?volledigeNaam . }
  OPTIONAL { ?Persoon_url <https://data.vlaanderen.be/ns/persoon#geslacht> ?geslacht_url . }
}
