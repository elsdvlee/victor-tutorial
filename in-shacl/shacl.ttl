<https://data.vlaanderen.be/doc/applicatieprofiel/organisatie-basis/ontwerpstandaard/toolchain4#AgentShape> a shacl:NodeShape;
  shacl:closed false;
  shacl:property [
    rdfs:seeAlso <https://data.vlaanderen.be/doc/applicatieprofiel/organisatie-basis/ontwerpstandaard/toolchain4#Agent.HeeftGeregistreerdeOrganisatie>;
    shacl:class <http://www.w3.org/ns/regorg#RegisteredOrganization>;
    shacl:description "Verwijst naar de geregistreerde organisatie waarmee de agent geassocieerd is."@nl;
    shacl:name "heeft geregistreerde organisatie"@nl;
    shacl:path <http://www.w3.org/ns/regorg#hasRegisteredOrganization>
  ], [
    rdfs:seeAlso <https://data.vlaanderen.be/doc/applicatieprofiel/organisatie-basis/ontwerpstandaard/toolchain4#Agent.RapporteertAan>;
    shacl:class dc:Agent;
    shacl:description "Verwijst naar de Agent waaraan de Agent verantwoording aflegt."@nl;
    shacl:name "rapporteert aan"@nl;
    shacl:path org:reportsTo
  ], [
    rdfs:seeAlso <https://data.vlaanderen.be/doc/applicatieprofiel/organisatie-basis/ontwerpstandaard/toolchain4#Agent.Houdt>;
    shacl:class org:Post;
    shacl:description "Geeft aan welke positie een agent heeft (typisch bij de organisatie waar de positie is gedefinieerd)."@nl;
    shacl:name "houdt"@nl;
    shacl:path org:holds
  ], [
    rdfs:seeAlso <https://data.vlaanderen.be/doc/applicatieprofiel/organisatie-basis/ontwerpstandaard/toolchain4#Agent.IsHoofdVan>;
    shacl:class org:Organization;
    shacl:description "Verwijst naar de organisatie waaraan een agent aan het hoofd staat of leiding geeft."@nl;
    shacl:name "is hoofd van"@nl;
    shacl:path org:headOf
  ], [
    rdfs:seeAlso <https://data.vlaanderen.be/doc/applicatieprofiel/organisatie-basis/ontwerpstandaard/toolchain4#Agent.IsLidVan>;
    shacl:class org:Organization;
    shacl:description "Niet nader bepaald lidmaatschap van een agent van een organisatie."@nl;
    shacl:name "is lid van"@nl;
    shacl:path org:memberOf
  ];
  shacl:targetClass dc:Agent .

